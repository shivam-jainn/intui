# Production / self-host environment
# Copy to .env and fill all required values.

# Core runtime
NODE_ENV=production
NEXT_PUBLIC_BETTER_AUTH_URL=https://your-app-domain.example
NEXT_PUBLIC_MIXER_STORY_FLAG=false
ANALYZE=false

# App runtime
DATABASE_URL=postgresql://user:password@postgres:5432/intui
REDIS_URL=redis://redis:6379

# Executor routing (production uses Cloud Run executor)
EXECUTOR_BASE_URL=https://your-cloud-run-executor.run.app
EXEC_CLIENT_EMAIL=your_exec_client_email
EXEC_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Backward-compatible alias (kept while migrating)
GCR_Host=https://your-cloud-run-executor.run.app

# OAuth credentials
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Executor storage mode (Cloud Run executor should use gcs)
EXECUTOR_STORAGE_MODE=gcs
GCS_BUCKET=your_executor_bucket_name
EXECUTOR_TIMEOUT_SECONDS=10

# GCP service account (required for storage + deploy scripts)
GCP_BUCKET_NAME=your_gcp_bucket_name
GCP_TYPE=service_account
GCP_PROJECT_ID=your_gcp_project_id
GCP_PRIVATE_KEY_ID=your_gcp_private_key_id
GCP_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GCP_CLIENT_EMAIL=your_gcp_client_email
GCP_CLIENT_ID=your_gcp_client_id
GCP_AUTH_URI=https://accounts.google.com/o/oauth2/auth
GCP_TOKEN_URI=https://oauth2.googleapis.com/token
GCP_AUTH_PROVIDER_X509_CERT_URL=https://www.googleapis.com/oauth2/v1/certs
GCP_CLIENT_X509_CERT_URL=https://www.googleapis.com/robot/v1/metadata/x509/your-client-email
GCP_UNIVERSE_DOMAIN=googleapis.com

# Optional LLM settings
LLM_PROVIDER=auto
LMSTUDIO_URL=http://localhost:1234
LMSTUDIO_MODEL=local-model
LMSTUDIO_STORY_MODEL=qwen/qwen3-8b
LMSTUDIO_DRIVER_MODEL=openai/gpt-oss-20b
LMSTUDIO_TEST_MODEL=openai/gpt-oss-20b
GROQ_API_KEY=your_groq_api_key
GEMINI_API_KEY=your_gemini_api_key
GROQ_MODEL=llama3-70b-8192
GEMINI_MODEL=gemini-1.5-flash
