# .env.example — copy to `.env` or `.env.local` and fill in real values
# -----------------------------------------------------------------------------
# IMPORTANT:
# - For multiline private keys (GCP/EXEC), replace actual newlines with \n
#   e.g. PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# -----------------------------------------------------------------------------

# App / runtime
NODE_ENV=development
ENV_MODE=development   # set to `production` when deploying

# Database (Prisma) — required for local & production
# Example (Postgres): postgres://user:pass@host:5432/dbname?schema=public
DATABASE_URL=postgresql://postgres:password@localhost:5432/intui?schema=public

# Authentication (social providers used by `better-auth`)
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# better-auth client (public) — used by the frontend
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000

# Auth toggle
# - Set to "false" to disable auth checks, endpoints and client behavior (useful for local dev)
AUTH_ENABLED=true
NEXT_PUBLIC_AUTH_ENABLED=true

# Feature flags (public) — exposed to client
NEXT_PUBLIC_MIXER_STORY_FLAG=false

# Execution / Executor (Cloud Run or local executor)
# - In development the app calls the local executor at http://127.0.0.1:8080
# - In production set GCR_Host to the base Cloud Run / executor host (no /execute)
GCR_Host=https://<your-cloud-run-or-executor-host>

# Service-account credentials used when calling the remote executor (production)
EXEC_CLIENT_EMAIL=executor-service-account@PROJECT.iam.gserviceaccount.com
EXEC_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_CONTENT_HERE\n-----END PRIVATE KEY-----\n"

# Google Cloud Platform (GCP) — used for storage / playground assets
GCP_BUCKET_NAME=your-gcp-bucket
GCP_TYPE=service_account
GCP_PROJECT_ID=your-gcp-project-id
GCP_PRIVATE_KEY_ID=your-private-key-id
GCP_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_CONTENT_HERE\n-----END PRIVATE KEY-----\n"
GCP_CLIENT_EMAIL=your-service-account@PROJECT.iam.gserviceaccount.com
GCP_CLIENT_ID=your-gcp-client-id
GCP_AUTH_URI=https://accounts.google.com/o/oauth2/auth
GCP_TOKEN_URI=https://oauth2.googleapis.com/token
GCP_AUTH_PROVIDER_X509_CERT_URL=https://www.googleapis.com/oauth2/v1/certs
GCP_CLIENT_X509_CERT_URL=https://www.googleapis.com/robot/v1/metadata/x509/your-service-account%40PROJECT.iam.gserviceaccount.com
GCP_UNIVERSE_DOMAIN=googleapis.com

# Optional / tooling
ANALYZE=false            # set to true to enable bundle analysis (npm run analyze)
