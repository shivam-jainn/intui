# Environment variables example for intui project

# Next.js public variables
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_MIXER_STORY_FLAG=false

# Environment Mode
NODE_ENV=development

# Build/debug flags
ANALYZE=false

# Database connection (replace with your own)
DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# OAuth credentials
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

FS_DATA_PATH=/path/to/local/data  # Only used in development for local file access, ignored in production
